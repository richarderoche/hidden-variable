    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
