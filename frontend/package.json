{
  "name": "frontend",
  "private": true,
  "scripts": {
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "predev": "npm run sanity:typegen",
    "dev": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sanity:typegen": "cd ../studio && sanity schema extract --enforce-required-fields --path ../sanity.schema.json && cd ../frontend && sanity typegen generate",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@next/env": "^16.2.6",
    "@next/third-parties": "^16.2.6",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "2.1.1",
    "@sanity/util": "^5.26.0",
    "classnames": "2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "4.3.0",
    "focus-trap-react": "^12.0.2",
    "gsap": "^3.15.0",
    "hamo": "latest",
    "hls.js": "^1.6.16",
    "lenis": "^1.3.23",
    "marqy": "^1.1.0",
    "next": "^16.2.6",
    "next-sanity": "^12.4.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "react-player": "^3.4.0",
    "sanity": "^5.26.0",
    "sanity-image": "^1.1.0",
    "sharp": "^0.34.5",
